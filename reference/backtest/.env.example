APP_NAME=Futures Backtest Platform
APP_ENV=dev
SECRET_KEY=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=720
POSTGRES_DSN=postgresql+psycopg://backtest:backtest@postgres:5432/backtest
REDIS_URL=redis://redis:6379/0
DUCKDB_PATH=/datasets/market.duckdb
