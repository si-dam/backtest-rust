DATASET_TZ=America/Chicago
INTERNAL_API_BASE=http://127.0.0.1:8000
ENABLE_WATCHER=false
WATCHER_INTERVAL_SECONDS=30
DEFAULT_OWNER_EMAIL=owner@example.com
DEFAULT_OWNER_PASSWORD=owner123
